{
  "name": "@outfitter/monorepo",
  "version": "0.0.0",
  "description": "Core shared configurations and utilities for Outfitter projects",
  "private": true,
  "engines": {
    "node": ">=20",
    "bun": "1.2.19"
  },
  "packageManager": "bun@1.2.19",
  "workspaces": [
    "packages/*",
    "packages/contracts/*",
    "shared"
  ],
  "scripts": {
    "dev": "bun --filter '*' dev",
    "build": "bun --filter '*' build",
    "build:turbo": "turbo run build",
    "test": "bun --filter '*' test",
    "test:turbo": "turbo run test",
    "typecheck": "bun --filter '*' typecheck",
    "typecheck:turbo": "turbo run typecheck",
    "lint": "bunx ultracite lint .",
    "lint:md": "markdownlint-cli2 .",
    "format": "bunx ultracite format .",
    "format:md": "markdownlint-cli2 . --fix",
    "deps:check": "syncpack list-mismatches",
    "deps:fix": "syncpack fix-mismatches",
    "deps:update": "syncpack update",
    "ci": "bun run lint && bun run lint:md && bun run typecheck && bun run test",
    "ci:local": "bun run format && bun run lint && bun run format:md && bun run typecheck && bun run test",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "config:mdlint": "bun ./scripts/generate-mdlint-config.mjs",
    "check:imports": "bun ./scripts/check-contracts-imports.ts",
    "prepare": "lefthook install && bun config:mdlint"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@changesets/cli": "^2.29.5",
    "@types/bun": "latest",
    "@types/glob": "^8.1.0",
    "@types/node": "24.3.0",
    "glob": "^11.0.3",
    "lefthook": "^1.12.3",
    "markdownlint-cli2": "^0.18.1",
    "syncpack": "^13.0.0",
    "turbo": "^2.5.5",
    "type-fest": "^4.41.0",
    "typescript": "5.9.2",
    "ultracite": "^5.1.5",
    "vitest": "3.2.4"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/outfitter-dev/monorepo.git"
  },
  "homepage": "https://github.com/outfitter-dev/monorepo#readme",
  "bugs": {
    "url": "https://github.com/outfitter-dev/monorepo/issues"
  }
}
