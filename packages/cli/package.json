{
  "name": "outfitter",
  "version": "1.1.0",
  "description": "Command-line tool for equipping your development journey with configurations and fieldguides",
  "type": "module",
  "bin": {
    "outfitter": "./dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "bun run ../../node_modules/.bin/tsc -p .",
    "dev": "bun src/index.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "bun run ../../node_modules/.bin/tsc --noEmit -p .",
    "lint": "bunx ultracite lint",
    "lint:fix": "bunx ultracite lint --write",
    "format": "bunx ultracite format",
    "format:check": "bunx ultracite format",
    "format:fix": "bunx ultracite format --write",
    "prepare": "bun run build"
  },
  "dependencies": {
    "@outfitter/contracts": "workspace:*",
    "@inquirer/prompts": "^3.3.0",
    "semver": "^7.6.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "execa": "^8.0.1",
    "fs-extra": "^11.2.0",
    "inquirer": "^9.2.12",
    "ora": "^8.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.7",
    "@types/node": "24.3.0",
    "@types/semver": "^7.5.0",
    "tsx": "^4.7.0",
    "typescript": "^5.9.2",
    "vitest": "3.2.4"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "cli",
    "outfitter",
    "developer-tools",
    "project-setup",
    "standards",
    "guidelines"
  ],
  "author": "Matt Galligan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/outfitter-dev/monorepo.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/outfitter-dev/monorepo/issues"
  },
  "homepage": "https://github.com/outfitter-dev/monorepo/tree/main/packages/cli#readme",
  "publishConfig": {
    "access": "public"
  }
}
